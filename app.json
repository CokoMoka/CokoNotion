{
  "expo": {
    "name": "CokoNotion",
    "slug": "CokoNotion",
    "version": "1.3.8",
    "orientation": "portrait",
    "icon": "./assets/images/Icono_CokoNa.png",
    "scheme": "cokonotion",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/wbg_Icono_CokoNa.png",
      "imageWidth": 300,
      "resizeMode": "contain",
      "backgroundColor": "#ffffff",
      "dark": {
        "backgroundColor": "#000000"
      }
    },
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "config": {
      "googleMaps": {
        "apiKey": "AIzaSyBt0aDPeJic1eh8Gd2MVXzprLEzLYtaK98"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.liobur.CokoNotion"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/Icono_CokoNa.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/wbg_Icono_CokoNa.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-sqlite",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "865576e2-dfbd-4151-b913-cf604e8e1095"
      }
    }
  }
}
